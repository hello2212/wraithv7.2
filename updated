	local function reconnectToggle()
		if guiToggleConn then guiToggleConn:Disconnect() end
		local targetKey=KEY_MAP[CFG.GuiToggleKey] or Enum.KeyCode.Insert
		guiToggleConn=UserInputService.InputBegan:Connect(function(input,gp)
			if gp then return end
