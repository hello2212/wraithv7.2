		local function RIV_snapshotGunParts(obj)
			for _, part in ipairs(obj:GetDescendants()) do
				if part:IsA("MeshPart") then
					RIV_registeredParts[part]=true
				elseif part:IsA("Part") then
					local hasMesh=false
					for _, child in ipairs(part:GetChildren()) do
						if child:IsA("SpecialMesh") or child:IsA("BlockMesh") or child:IsA("CylinderMesh") then
							hasMesh=true; break
						end
					end
					if hasMesh then RIV_registeredParts[part]=true end
				end
				if part:IsA("UnionOperation") or part:IsA("CornerWedgePart") or part:IsA("WedgePart") then
					RIV_registeredParts[part]=true
				end
			end
		end

		local function RIV_isRegistered(part)
			return RIV_registeredParts[part]==true and part.Parent~=nil
		end

		local function RIV_hideHitboxParts(obj)
			for _, part in ipairs(obj:GetDescendants()) do
				if part:IsA("Part") and not RIV_registeredParts[part] then
					part.Transparency=1; part.CastShadow=false
				end
			end
		end

