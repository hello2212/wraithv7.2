			if RAGE_KillAllConn then RAGE_KillAllConn:Disconnect(); RAGE_KillAllConn=nil end
		end
		local function RAGE_startKillAll()
			RAGE_stopKillAll()
			RAGE_KillAllConn=RunService.RenderStepped:Connect(function()
				if not CFG.RAGE_KillAllEnabled then RAGE_stopKillAll(); return end
				local myHRP=getHRP(LocalPlayer); if not myHRP then return end
				local best,bd=nil,math.huge
				for _,plr in ipairs(Players:GetPlayers()) do
					if plr==LocalPlayer or not isAlive(plr) then continue end
					local hrp=getHRP(plr); if not hrp then continue end
					local d=(myHRP.Position-hrp.Position).Magnitude
					if d<bd then bd=d; best=plr end
				end
				if not best then return end
				local tHRP=getHRP(best); if not tHRP then return end
				-- position behind target
				local behindPos=tHRP.Position - tHRP.CFrame.LookVector*3
				if (myHRP.Position-behindPos).Magnitude>4 then
					local tweenTime=math.max(0.05,CFG.RAGE_TweenSpeed)
					TweenService:Create(myHRP,
						TweenInfo.new(tweenTime,Enum.EasingStyle.Linear),
						{CFrame=CFrame.new(behindPos,tHRP.Position)}):Play()
				end
				local tp=getTargetPart(best)
				if tp then
					Camera.CFrame=Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position,tp.Position),0.35)
				end
			end)
		end

