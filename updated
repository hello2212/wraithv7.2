-- =============================================
-- HELPERS
-- =============================================
local function getChar(plr) return plr and plr.Character end
local function getHRP(plr)
	local c=getChar(plr); if not c then return nil end
	return c:FindFirstChild("HumanoidRootPart") or c:FindFirstChild("UpperTorso") or c:FindFirstChild("Torso")
end
local function getHum(plr) local c=getChar(plr); return c and c:FindFirstChildOfClass("Humanoid") end
local function isAlive(plr) local h=getHum(plr); return h and h.Health>0 end

local function isEnemy(plr)
	if plr==LocalPlayer then return false end
	if gameType=="AR2" or gameType=="BB" then return true end
	if not CFG.TeamCheck then return true end
	if LocalPlayer.Team~=nil and plr.Team~=nil then return LocalPlayer.Team~=plr.Team end
	for _,myVal in ipairs(LocalPlayer:GetChildren()) do
		if myVal:IsA("StringValue") or myVal:IsA("IntValue")
			or myVal:IsA("NumberValue") or myVal:IsA("BrickColorValue") then
			local tv=plr:FindFirstChild(myVal.Name)
			if tv and tv.ClassName==myVal.ClassName then
				return tostring(myVal.Value)~=tostring(tv.Value)
			end
		end
	end
	return true
end

local function isAimbotWhitelisted(plr)
	for _,n in ipairs(CFG.AimbotWhitelist) do if plr.Name:lower()==n:lower() then return true end end
	return false
end
local function isAimbotTarget(plr)
	if plr==LocalPlayer then return false end
	if not isAlive(plr) then return false end
	if isAimbotWhitelisted(plr) then return false end
	if not isEnemy(plr) then return false end
	return true
end
local function getTargetPart(plr)
	local char=getChar(plr); if not char then return nil end
	if CFG.TargetPart=="Head" then return char:FindFirstChild("Head") end
	return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
		or char:FindFirstChild("HumanoidRootPart")
end
local function isVisible(targetPart)
	if not CFG.VisibleCheck or not targetPart then return true end
	local char=getChar(LocalPlayer); if not char then return false end
	local ray=Ray.new(Camera.CFrame.Position,(targetPart.Position-Camera.CFrame.Position).Unit*500)
	local hit,pos=workspace:FindPartOnRayWithIgnoreList(ray,{char},false,true)
	if hit then return (pos-targetPart.Position).Magnitude<5 end
	return true
end

local function getClosestEnemyRoot(maxDistance)
	local myRoot=getHRP(LocalPlayer)
	if not myRoot then return nil,nil end
	local bestRoot,bestPlayer,bestDist=nil,nil,maxDistance or math.huge
	for _,plr in ipairs(Players:GetPlayers()) do
		if isAimbotTarget(plr) then
			local root=getHRP(plr)
			if root then
				local dist=(root.Position-myRoot.Position).Magnitude
				if dist<bestDist then
					bestDist=dist
					bestRoot=root
					bestPlayer=plr
				end
			end
		end
	end
	return bestRoot,bestPlayer
end

