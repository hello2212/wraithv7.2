local rhtGunModActive = false
local rhtOrigValues   = {}
local rhtFullAutoConn = nil

local RHT_RECOIL_NAMES  = {"recoil","verticalrecoil","horizontalrecoil","kickback","camrecoil","recoilmult"}
local RHT_SPREAD_NAMES  = {"spread","bloomspread","accuracy","inaccuracy","bulletspread"}
local RHT_AMMO_NAMES    = {"ammo","magazine","clip","bullets","currentammo","loadedammo","maxammo","reserveammo"}
local RHT_SWAY_NAMES    = {"sway","aimswayspeed","swayamount","swaymagnitude"}
local RHT_FIRERATE_NAMES= {"firerate","rpm","fireinterval","cooldown","delay","firedelay","debounce","firecd"}

local function rhtRestoreValues()
	for d, orig in pairs(rhtOrigValues) do
		pcall(function() if d and d.Parent then d.Value = orig end end)
	end
	rhtOrigValues = {}
end

local function rhtApplyGunMods(tool)
	if not tool then return end
	for _, d in ipairs(tool:GetDescendants()) do
		if not (d:IsA("NumberValue") or d:IsA("IntValue")) then continue end
		local n = d.Name:lower()

		local function snapshot()
			if not rhtOrigValues[d] then rhtOrigValues[d] = d.Value end
		end

		if CFG.RHT_NoRecoil then
			for _, rn in ipairs(RHT_RECOIL_NAMES) do
				if n == rn or n:find(rn) then snapshot(); d.Value = 0; break end
			end
		end

		if CFG.RHT_NoSpread then
			for _, sn in ipairs(RHT_SPREAD_NAMES) do
				if n == sn or n:find(sn) then snapshot(); d.Value = 0; break end
			end
		end

		if CFG.RHT_NoSway then
			for _, sw in ipairs(RHT_SWAY_NAMES) do
				if n == sw or n:find(sw) then snapshot(); d.Value = 0; break end
			end
		end

		if CFG.RHT_InfAmmo then
			for _, an in ipairs(RHT_AMMO_NAMES) do
				if n == an or n:find(an) then
					if d.Value >= 0 then d.Value = 9999 end
					break
				end
			end
		end

		if CFG.RHT_FastShoot then
			for _, fr in ipairs(RHT_FIRERATE_NAMES) do
				if n == fr or n:find(fr) then
					snapshot()
					local orig = rhtOrigValues[d]
					local isDelay = n:find("delay") or n:find("cooldown") or n:find("debounce")
						or n:find("interval") or n:find("cd")
					if isDelay then d.Value = math.max(0.001, orig / 3)
					else d.Value = orig * 3 end
					break
				end
			end
		end
	end
end

local function rhtStopMods()
	rhtGunModActive = false
	if rhtFullAutoConn then rhtFullAutoConn:Disconnect(); rhtFullAutoConn = nil end
	rhtRestoreValues()
end

local function rhtStartMods()
	rhtRestoreValues()
	rhtGunModActive = true
	task.spawn(function()
		while rhtGunModActive do
			local char = LocalPlayer.Character
			local tool = char and char:FindFirstChildOfClass("Tool")
			if tool then
				rhtApplyGunMods(tool)
				if CFG.RHT_FullAuto and lmbHeld then
					local fired = false
					for _, d in ipairs(tool:GetDescendants()) do
						if d:IsA("RemoteEvent") then
							local nm = d.Name:lower()
							if nm:find("fire") or nm:find("shoot") or nm:find("attack") or nm:find("bullet") then
								pcall(function() d:FireServer() end)
								fired = true; break
							end
						end
					end
					if not fired then pcall(function() tool:Activate() end) end
				end
			end
			task.wait(0.08)
		end
	end)
end

