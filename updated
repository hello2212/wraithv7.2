		-- ── Wallbang (hookmetamethod) ──────────────────────────────
		local RAGE_WallbangHooked = false
		local function RAGE_initWallbang()
			if not hookmetamethod or RAGE_WallbangHooked then return end
			RAGE_WallbangHooked = true
			local oldNamecall
			oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
				local method = getnamecallmethod()
				if not checkcaller() and method == "Raycast" and CFG.RAGE_Wallbang and self == workspace then
					local args = {...}
					local params = args[3]
					if params and typeof(params) == "RaycastParams" then
						local ignore = params.FilterDescendantsInstances or {}
						local mapFolder = workspace:FindFirstChild("Map") or workspace:FindFirstChild("MapFolder")
						if mapFolder then
							table.insert(ignore, mapFolder)
							params.FilterDescendantsInstances = ignore
						end
					end
					return oldNamecall(self, args[1], args[2], params)
				end
				return oldNamecall(self, ...)
			end))
			notify("Wallbang Hook","Hookmetamethod installed.",2)
		end

