-- =============================================
-- ESP (Player & Bad Business) — updated in throttled loop
-- =============================================
local espFolder=Instance.new("Folder",CoreGui); espFolder.Name="WraithHubESP"
local espCache,skelCache={},{}

local SKEL_PAIRS={
	{"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
	{"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
	{"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
	{"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},
	{"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},
	{"Head","Torso"},{"Torso","Left Arm"},{"Torso","Right Arm"},
	{"Torso","Left Leg"},{"Torso","Right Leg"},
}

local function clearESP(plrOrChar)
	if not espCache[plrOrChar] then return end
	pcall(function()
		if espCache[plrOrChar].Highlight then espCache[plrOrChar].Highlight:Destroy() end
		if espCache[plrOrChar].Billboard then espCache[plrOrChar].Billboard:Destroy() end
	end)
	espCache[plrOrChar]=nil
end
local function clearAllESP() for p in pairs(espCache) do clearESP(p) end end
local function clearSkeleton(plr)
	if not skelCache[plr] then return end
	for _,ln in ipairs(skelCache[plr]) do pcall(function() ln:Remove() end) end
	skelCache[plr]=nil
end
local function clearAllSkeleton() for p in pairs(skelCache) do clearSkeleton(p) end end

local function drawSkeleton(plr,color)
	if not CFG.ShowSkeleton or not CFG.PlayerESP then clearSkeleton(plr) return end
	local char=getChar(plr); if not char then clearSkeleton(plr) return end
	if not skelCache[plr] then skelCache[plr]={} end
	local idx=0
	for _,pair in ipairs(SKEL_PAIRS) do
		local pA,pB=char:FindFirstChild(pair[1]),char:FindFirstChild(pair[2])
		if not(pA and pB) then continue end
		local sA,onA=Camera:WorldToScreenPoint(pA.Position)
		local sB,onB=Camera:WorldToScreenPoint(pB.Position)
		if not(onA and onB and sA.Z>0 and sB.Z>0) then continue end
		idx+=1
		local ln=skelCache[plr][idx]
		if not ln then
			ln=Drawing.new("Line"); ln.Thickness=1.5; ln.Transparency=1; ln.ZIndex=5
			skelCache[plr][idx]=ln
		end
		ln.From=Vector2.new(sA.X,sA.Y); ln.To=Vector2.new(sB.X,sB.Y)
		ln.Color=color; ln.Visible=true
	end
	for i=idx+1,#skelCache[plr] do
		if skelCache[plr][i] then skelCache[plr][i].Visible=false end
	end
end

local function updateESP()
	if not CFG.PlayerESP then clearAllESP(); clearAllSkeleton() return end
	local myHRP=getHRP(LocalPlayer)
	
	-- Bad Business ESP Handling
	if gameType == "BB" then
		local active = {}
		local camPos = Camera.CFrame.Position
		for _, charData in ipairs(GetBBCharacters()) do
			local char = charData.Character
			local head = charData.Head
			local chest = charData.Body:FindFirstChild("Chest") or head
			
			if (head.Position - camPos).Magnitude < 1 then continue end
			active[char] = true
			
			local enemy = isBBEnemy(charData)
			local color = enemy and CFG.EnemyColor or CFG.AllyColor
			
			if CFG.ShowBox then
				if not espCache[char] then
					local hl=Instance.new("Highlight")
					hl.FillTransparency=0.55; hl.OutlineTransparency=0
					hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop; hl.Parent=espFolder
					local bb=Instance.new("BillboardGui"); bb.AlwaysOnTop=true
					bb.Size=UDim2.new(0,200,0,55); bb.StudsOffset=Vector3.new(0,3.5,0)
					bb.MaxDistance=CFG.ESPMaxDist; bb.Parent=espFolder
					local tl=Instance.new("TextLabel"); tl.BackgroundTransparency=1
					tl.Size=UDim2.new(1,0,1,0); tl.Font=Enum.Font.GothamBold
					tl.TextStrokeTransparency=0; tl.TextStrokeColor3=Color3.new(0,0,0); tl.Parent=bb
					espCache[char]={Highlight=hl,Billboard=bb,Label=tl}
				end
				local d=espCache[char]
				d.Highlight.Adornee=char; d.Highlight.FillColor=color
				d.Highlight.OutlineColor=color; d.Billboard.Adornee=chest
				d.Label.TextColor3=color; d.Label.TextSize=CFG.TextSize
				
				local dist = math.floor((head.Position - camPos).Magnitude)
				local parts = {}
				if CFG.ShowNames then table.insert(parts, char.Name) end
				if CFG.ShowDist then table.insert(parts, dist.."m") end
				d.Label.Text=table.concat(parts," • ")
			else clearESP(char) end
		end
		
		for p in pairs(espCache) do
			if typeof(p) == "Instance" and not active[p] then clearESP(p) end
		end
		return
	end

	for _,plr in ipairs(Players:GetPlayers()) do
		if plr==LocalPlayer then continue end
		local char,hrp,hum=getChar(plr),getHRP(plr),getHum(plr)
		if not char or not hrp or not hum or not isAlive(plr) then
			clearESP(plr); clearSkeleton(plr); continue
		end
		if myHRP and (hrp.Position-myHRP.Position).Magnitude>CFG.ESPMaxDist then
			clearESP(plr); clearSkeleton(plr); continue
		end
		local enemy=isEnemy(plr)
		local color=enemy and CFG.EnemyColor or CFG.AllyColor
		if CFG.ShowBox then
			if not espCache[plr] then
				local hl=Instance.new("Highlight")
				hl.FillTransparency=0.55; hl.OutlineTransparency=0
				hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop; hl.Parent=espFolder
				local bb=Instance.new("BillboardGui"); bb.AlwaysOnTop=true
				bb.Size=UDim2.new(0,200,0,55); bb.StudsOffset=Vector3.new(0,3.5,0)
				bb.MaxDistance=CFG.ESPMaxDist; bb.Parent=espFolder
				local tl=Instance.new("TextLabel"); tl.BackgroundTransparency=1
				tl.Size=UDim2.new(1,0,1,0); tl.Font=Enum.Font.GothamBold
				tl.TextStrokeTransparency=0; tl.TextStrokeColor3=Color3.new(0,0,0); tl.Parent=bb
				espCache[plr]={Highlight=hl,Billboard=bb,Label=tl}
			end
			local d=espCache[plr]
			d.Highlight.Adornee=char; d.Highlight.FillColor=color
			d.Highlight.OutlineColor=color; d.Billboard.Adornee=hrp
			d.Label.TextColor3=color; d.Label.TextSize=CFG.TextSize
			if CFG.ShowNames or CFG.ShowTeam or CFG.ShowDist or CFG.ShowHP then
				local dist=myHRP and math.floor((hrp.Position-myHRP.Position).Magnitude) or 0
				local parts={}
				if CFG.ShowNames then table.insert(parts,plr.Name) end
				if CFG.ShowTeam  then table.insert(parts,"[".. (plr.Team and plr.Team.Name or "None").."]") end
				if CFG.ShowDist  then table.insert(parts,dist.."m") end
				if CFG.ShowHP    then table.insert(parts,"❤ "..math.floor(hum.Health).."/"..math.floor(hum.MaxHealth)) end
				d.Label.Text=table.concat(parts," • ")
			else d.Label.Text="" end
		else clearESP(plr) end
	end
	for p in pairs(espCache) do if typeof(p) == "Instance" and p:IsA("Player") and not p.Parent then clearESP(p); clearSkeleton(p) end end
	for p in pairs(skelCache) do if not p.Parent then clearSkeleton(p) end end
end

Players.PlayerRemoving:Connect(function(plr)
	clearESP(plr)
	clearSkeleton(plr)
end)

