local function ar2GetLootWorldPos(inst)
	if not(inst and inst.Parent) then return nil end
	if inst:IsA("BasePart")    then return inst.Position end
	if inst:IsA("Attachment")  then return inst.WorldPosition end
	if inst:IsA("CFrameValue") then return inst.Value.Position end
	if inst:IsA("Model") then
		local primary=inst.PrimaryPart or inst:FindFirstChildWhichIsA("BasePart",true)
		if primary then return primary.Position end
		local ok,pivot=pcall(function() return inst:GetPivot() end)
		if ok and typeof(pivot)=="CFrame" then return pivot.Position end
	end
	return nil
end

local AR2_ItemNodes, AR2_ItemNodeLastScan = {}, 0

local function scanAR2ItemNodes()
	AR2_ItemNodes = {}
	local map = workspace:FindFirstChild("Map"); if not map then return end
	local elements = map:FindFirstChild("Elements"); if not elements then return end
	for _, el in ipairs(elements:GetChildren()) do
		local detail = el:FindFirstChild("Detail", true)
		if detail then
			for _, i in ipairs(detail:GetChildren()) do
				if i:IsA("Model") and i.Name == "Model" then
					AR2_ItemNodes[i] = true
				end
			end
		end
	end
end

local function updateAR2ItemESP()
	if not CFG.AR2ItemESP then
		disableWorldESPObjects(AR2_ItemESP_Objects)
		return
	end
	if tick() - AR2_ItemNodeLastScan > AR2_WORLD_RESCAN_DELAY then
		AR2_ItemNodeLastScan = tick()
		scanAR2ItemNodes()
	end

	local myHRP  = getHRP(LocalPlayer)
	if not myHRP then return end
	local active = {}
	local visibleCount = 0

	for node in pairs(AR2_ItemNodes) do
		if not node or not node.Parent then continue end
		local wPos = ar2GetLootWorldPos(node)
		if not wPos then continue end
		local dist = (myHRP.Position - wPos).Magnitude

		if dist <= CFG.AR2ItemESPDist and visibleCount < AR2_WORLD_MAX_ITEMS then
			active[node] = true
			visibleCount += 1

			if not AR2_ItemESP_Objects[node] then
				local att = Instance.new("Attachment")
				att.Name           = "Wraith_AR2_ItemESP"
				att.Parent         = workspace.Terrain
				att.WorldPosition  = wPos
				local bb, nl, dl = makeWorldBillboard(att, 1, 130, 34)
				nl.TextColor3 = Color3.fromRGB(110, 230, 110)
				nl.Text       = "📦  Item"
				AR2_ItemESP_Objects[node] = { BB = bb, NameLbl = nl, DistLbl = dl, Att = att }
			end

			local data = AR2_ItemESP_Objects[node]
			data.Att.WorldPosition = wPos
			data.DistLbl.Text      = math.floor(dist) .. "m"
			data.BB.Enabled        = true

		elseif AR2_ItemESP_Objects[node] then
			AR2_ItemESP_Objects[node].BB.Enabled = false
		end
	end

	trimWorldESPObjects(AR2_ItemESP_Objects, active, true)
end

local AR2_LOOTBOX_KEYWORDS = {"crate","box","loot","supply","cache","chest","drop","container","case"}
local function ar2IsLootBoxName(name)
	local lower = name:lower()
	for _, kw in ipairs(AR2_LOOTBOX_KEYWORDS) do
		if lower:find(kw) then return true end
	end
	return false
end

local function scanAR2LootBoxNodes()
	AR2_LootBoxEntries = {}
	local map = workspace:FindFirstChild("Map"); if not map then return end
	local function recurse(parent, depth)
		if depth > 4 then return end
		for _, child in ipairs(parent:GetChildren()) do
			if (child:IsA("Model") or child:IsA("BasePart") or child:IsA("Folder"))
				and ar2IsLootBoxName(child.Name) then
				AR2_LootBoxEntries[child] = true
			end
			recurse(child, depth + 1)
		end
	end
	recurse(map, 0)
end

