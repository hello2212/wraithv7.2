local function updateXRay()
	if not CFG.XRayEnabled then
		for model,hl in pairs(xrayCache) do pcall(function() hl:Destroy() end) end
		xrayCache={}; return
	end
	local myChar=getChar(LocalPlayer); local active={}
	local function processModel(model)
		if not model:IsA("Model") or model==myChar then return end
		local hum=model:FindFirstChildOfClass("Humanoid")
		if not(hum and hum.Health>0) then
			if xrayCache[model] then pcall(function() xrayCache[model]:Destroy() end); xrayCache[model]=nil end
			return
		end
		active[model]=true
		if not xrayCache[model] then
			local hl=Instance.new("Highlight")
			hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop
			hl.FillColor=Color3.fromRGB(255,40,40); hl.FillTransparency=0.45
