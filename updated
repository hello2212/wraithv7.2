local function doAntiAim(hrp)
	if not CFG.AntiAim or not hrp then return end
	local spd = CFG.AntiAimSpeed

	if CFG.AntiAimMode=="Spin" then
		-- Classic horizontal spin
		antiAimAngle=(antiAimAngle+spd)%360
		hrp.CFrame=CFrame.new(hrp.Position)*CFrame.Angles(0,math.rad(antiAimAngle),0)

	elseif CFG.AntiAimMode=="Jitter" then
		-- Rapid left-right flip
		aaJFlip=-aaJFlip
		hrp.CFrame=CFrame.new(hrp.Position)*CFrame.Angles(0,math.rad(aaJFlip*spd),0)

	elseif CFG.AntiAimMode=="FlatFlip" then
		-- 180-degree snap each frame
		antiAimAngle=(antiAimAngle+180)%360
		hrp.CFrame=CFrame.new(hrp.Position)*CFrame.Angles(0,math.rad(antiAimAngle),0)

	elseif CFG.AntiAimMode=="DesyncSpin" then
		-- Spins AND tilts on X axis simultaneously — breaks hit registration
		antiAimAngle=(antiAimAngle+spd)%360
		hrp.CFrame=CFrame.new(hrp.Position)
			*CFrame.Angles(math.rad(math.sin(antiAimAngle*0.05)*60),math.rad(antiAimAngle),0)

	elseif CFG.AntiAimMode=="UpDown" then
		-- Rapidly pitches forward/backward — hard to hit head
		aaJFlip=-aaJFlip
		hrp.CFrame=CFrame.new(hrp.Position)*CFrame.Angles(math.rad(aaJFlip*spd),0,0)

	elseif CFG.AntiAimMode=="Random" then
		-- Randomised rotation on all three axes every frame
		hrp.CFrame=CFrame.new(hrp.Position)
			*CFrame.Angles(
				math.rad(math.random(-spd,spd)),
				math.rad(math.random(-180,180)),
				math.rad(math.random(-spd,spd))
			)

	elseif CFG.AntiAimMode=="Scramble" then
		-- Scatters visible body parts in random directions around the HRP.
		-- Rivals-specific: works best where parts are individually networked.
		-- Parts bounce back each frame since we set them every RenderStep.
		local char=hrp.Parent; if not char then return end
		local limbs=getAaLimbs(char)
		for _,part in ipairs(limbs) do
			pcall(function()
				local offset=Vector3.new(
					(math.random()-0.5)*spd*0.4,
					(math.random()-0.5)*spd*0.4,
					(math.random()-0.5)*spd*0.4
				)
				part.CFrame=CFrame.new(hrp.Position+offset)
					*CFrame.Angles(math.rad(math.random(0,360)),math.rad(math.random(0,360)),0)
			end)
		end
		-- Also spin the HRP itself
		antiAimAngle=(antiAimAngle+spd)%360
		hrp.CFrame=CFrame.new(hrp.Position)*CFrame.Angles(0,math.rad(antiAimAngle),0)
	end
end

