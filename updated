local function bssInit()
	if BSS_Events then return true end
	local ok = pcall(function()
		local RS        = game:GetService("ReplicatedStorage")
		BSS_Events      = RS:WaitForChild("Events", 10)
		BSS_ToolCollect = BSS_Events:WaitForChild("ToolCollect", 10)
		BSS_HiveCmd     = BSS_Events:WaitForChild("PlayerHiveCommand", 10)
		BSS_ClaimHive   = BSS_Events:WaitForChild("ClaimHive", 10)
		BSS_Honeycombs  = workspace:WaitForChild("Honeycombs", 10)
		BSS_FlowerZones = workspace:WaitForChild("FlowerZones", 10)
		BSS_CoreStats   = LocalPlayer:WaitForChild("CoreStats", 10)
	end)
	if not ok or not BSS_Events then
		BSS_Events = nil
		return false
	end
	return true
end

local function bssGetHRP()
	local char = LocalPlayer.Character
	return char and char:FindFirstChild("HumanoidRootPart")
end

local function bssGetOrClaimHive()
	if not BSS_Honeycombs then return nil end
	for _, hive in ipairs(BSS_Honeycombs:GetChildren()) do
		local owner = hive:FindFirstChild("Owner")
		if owner and tostring(owner.Value) == tostring(LocalPlayer.Name) then
			return hive
		end
	end
	for _, hive in ipairs(BSS_Honeycombs:GetChildren()) do
		local owner   = hive:FindFirstChild("Owner")
		local hiveID  = hive:FindFirstChild("HiveID")
		local spawnPos= hive:FindFirstChild("SpawnPos")
		if owner and owner.Value == nil and hiveID and spawnPos then
			local hrp = bssGetHRP()
			if hrp then
				hrp.CFrame = CFrame.new(spawnPos.Value.Position + Vector3.new(0, 3, 0))
				task.wait(1)
				BSS_ClaimHive:FireServer(hiveID.Value)
				task.wait(1.5)
				for _, h2 in ipairs(BSS_Honeycombs:GetChildren()) do
					local o2 = h2:FindFirstChild("Owner")
					if o2 and tostring(o2.Value) == tostring(LocalPlayer.Name) then
						return h2
					end
				end
			end
			break
		end
	end
	return nil
end

local function bssTeleportToHive()
	if not BSS_PlayerHive then return end
	local hrp = bssGetHRP(); if not hrp then return end
	local spawnPos = BSS_PlayerHive:FindFirstChild("SpawnPos")
	if spawnPos then
		hrp.CFrame = CFrame.new(spawnPos.Value.Position + Vector3.new(0, 3, 0))
	end
end

local function bssConvertPollen()
	if not bssInit() then return end
	if not BSS_CoreStats then return end
	local pollenStat = BSS_CoreStats:FindFirstChild("Pollen")
	if not pollenStat or pollenStat.Value == 0 then
		notify("BSS","No pollen to convert",1.5); return
	end
	bssTeleportToHive()
	task.wait(1)
	BSS_HiveCmd:FireServer("ToggleHoneyMaking")
	local waited = 0
	while pollenStat.Value > 0 and waited < 60 do
		task.wait(1); waited += 1
	end
	task.wait(8)
end

local function bssGetPollenTool()
	local char = LocalPlayer.Character; if not char then return nil end
	local t = char:FindFirstChildOfClass("Tool")
	if not t then t = LocalPlayer.Backpack:FindFirstChildOfClass("Tool") end
	return t
end

local function bssStopAll()
	bssFarmRunning = false
	if bssToolCollectConn then bssToolCollectConn:Disconnect(); bssToolCollectConn = nil end
end

local function bssStartFarm()
	bssStopAll()
	if not bssInit() then
		notify("BSS","Failed to connect BSS events — wrong game?",3); return
	end
	BSS_PlayerHive = bssGetOrClaimHive()
	if not BSS_PlayerHive then
		notify("BSS","Could not find or claim a hive",3); return
	end

	bssFarmRunning = true
	bssToolCollectConn = RunService.Heartbeat:Connect(function()
		if not bssFarmRunning then
			bssToolCollectConn:Disconnect(); bssToolCollectConn = nil; return
		end
		pcall(function() BSS_ToolCollect:FireServer() end)
	end)

	-- Token Gathering Loop
	task.spawn(function()
		while bssFarmRunning and CFG.BSS_AutoFarm do
			task.wait(0.1)
			if not CFG.BSS_AutoCollect then continue end
			local hrp = bssGetHRP()
			if not hrp then continue end

			local collectibles = workspace:FindFirstChild("Collectibles")
			if collectibles then
				for _, item in ipairs(collectibles:GetChildren()) do
					if not bssFarmRunning or not CFG.BSS_AutoCollect then break end
					pcall(function()
						if not item or not item.Parent then return end
						local itemPos = nil
						local basePart = nil
						if item:IsA("BasePart") then 
							itemPos = item.Position
							basePart = item
						elseif item:IsA("Model") then
							local p = item.PrimaryPart or item:FindFirstChildOfClass("BasePart")
							if p then 
								itemPos = p.Position 
								basePart = p
							end
						end
						
						-- Ignore tokens that are static map objects (stuck at 0.7 transparency)
						if basePart and math.abs(basePart.Transparency - 0.7) < 0.05 then return end

						if itemPos and (itemPos - hrp.Position).Magnitude < CFG.BSS_TokenRadius then
							if CFG.BSS_MovementMethod == "Tween" then
								local dist = (itemPos - hrp.Position).Magnitude
								local speed = math.max(CFG.BSS_FarmSpeed, 50)
								local twInfo = TweenInfo.new(dist / speed, Enum.EasingStyle.Linear)
								local tw = TweenService:Create(hrp, twInfo, {CFrame = CFrame.new(itemPos)})
								tw:Play()
								tw.Completed:Wait() 
							elseif CFG.BSS_MovementMethod == "Walk" then
								local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
								if hum then
									hum:MoveTo(itemPos)
									hum.MoveToFinished:Wait()
								end
							else
								hrp.CFrame = CFrame.new(itemPos)
								task.wait(0.05)
							end
						end
					end)
				end
			end
		end
	end)

	-- Field Farming Loop
	task.spawn(function()
		local afkTimer = 0
		while bssFarmRunning and CFG.BSS_AutoFarm do
			task.wait(0.5)
			afkTimer += 0.5
			if CFG.BSS_AntiAFK and afkTimer >= 25 then
				afkTimer = 0
				local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
				if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
			end

			local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
			if hum then hum.WalkSpeed = CFG.BSS_SpeedHack and CFG.BSS_FarmSpeed or 16 end

			local hrp = bssGetHRP(); if not hrp then continue end
			local pollenStat   = BSS_CoreStats:FindFirstChild("Pollen")
			local capacityStat = BSS_CoreStats:FindFirstChild("Capacity")
			local pollen   = pollenStat   and pollenStat.Value   or 0
			local capacity = capacityStat and capacityStat.Value or 100

			if pollen >= capacity then
				if CFG.BSS_AutoConvert then
					notify("BSS","Bag full ("..pollen.."/"..capacity..") — depositing",2)
					bssConvertPollen()
				else
					task.wait(2)
				end
				continue
			end

			local fieldZone = BSS_FlowerZones:FindFirstChild(CFG.BSS_AutoFarmField)
			if not fieldZone then
				local targetName = CFG.BSS_AutoFarmField:lower():gsub(" field", ""):gsub("%s+", "")
				for _, zone in ipairs(BSS_FlowerZones:GetChildren()) do
					local zName = zone.Name:lower():gsub(" field", ""):gsub("%s+", "")
					if zName == targetName or zName:find(targetName) then
						fieldZone = zone; break
					end
				end
				if not fieldZone then
					notify("BSS","Field '"..CFG.BSS_AutoFarmField.."' not found",3)
					task.wait(3); continue
				end
			end

			local tool = bssGetPollenTool()
			local clickEvent = tool and tool:FindFirstChild("ClickEvent")

			local fieldCF = fieldZone.CFrame
			local radius  = 30
			local rx = (math.random() - 0.5) * 2 * radius
			local rz = (math.random() - 0.5) * 2 * radius
			local farmPos = fieldCF.Position + Vector3.new(rx, 5, rz)
			
			if CFG.BSS_MovementMethod == "Tween" then
				local dist = (farmPos - hrp.Position).Magnitude
				local speed = math.max(CFG.BSS_FarmSpeed, 50)
				local twInfo = TweenInfo.new(dist / speed, Enum.EasingStyle.Linear)
				local tw = TweenService:Create(hrp, twInfo, {CFrame = CFrame.new(farmPos)})
				tw:Play()
				task.wait(0.2) 
			elseif CFG.BSS_MovementMethod == "Walk" and hum then
				hum:MoveTo(farmPos)
				task.wait(0.2)
			else
				hrp.CFrame = CFrame.new(farmPos)
				task.wait(0.1)
			end

			if tool and clickEvent then
				if tool.Parent ~= LocalPlayer.Character then tool.Parent = LocalPlayer.Character end
				for i = 1, 25 do
					if not bssFarmRunning then break end
					pcall(function() clickEvent:FireServer(hrp.CFrame) end)
					task.wait(0.2)
				end
			else
				task.wait(5)
			end
		end

		local hum2 = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
		if hum2 then hum2.WalkSpeed = 16 end
		bssStopAll()
	end)
end

