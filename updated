			rp.IgnoreWater=true
			local result=workspace:Raycast(unitRay.Origin,unitRay.Direction*CFG.AimbotRange,rp)
			if not result or not result.Instance then return nil end
			local hitModel=result.Instance
			repeat
				hitModel=hitModel.Parent
			until not hitModel or hitModel==workspace or hitModel:FindFirstChildOfClass("Humanoid")
			if not hitModel or hitModel==workspace then return nil end
			local hum=hitModel:FindFirstChildOfClass("Humanoid")
			if not hum or hum.Health<=0 then return nil end
			local plr=Players:GetPlayerFromCharacter(hitModel)
			if not plr or not isAimbotTarget(plr) then return nil end
			return plr,hitModel,hum
		end

