-- ARSENAL WEAPON MODS
-- =============================================
local origFireRate={}
local arsenalHandles={infAmmo=false,fireRate=false,fullAuto=false}

local function setupInfAmmo(tool)
	arsenalHandles.infAmmo=true
	task.spawn(function()
		while arsenalHandles.infAmmo and CFG.InfAmmo and tool and tool.Parent do
			for _,d in ipairs(tool:GetDescendants()) do
				if d:IsA("IntValue") or d:IsA("NumberValue") then
					local n=d.Name:lower()
					if(n=="ammo" or n=="bullets" or n=="magazine" or n=="clip"
						or n:find("ammo") or n:find("bullet") or n:find("mag") or n:find("clip"))
						and d.Value<500 then d.Value=9999 end
				end
			end
			task.wait(0.05)
		end
	end)
end
local function setupFireRate(tool)
	arsenalHandles.fireRate=true
	task.spawn(function()
		while arsenalHandles.fireRate and CFG.FireRateEnabled and tool and tool.Parent do
			for _,d in ipairs(tool:GetDescendants()) do
				if d:IsA("NumberValue") or d:IsA("IntValue") then
					local n=d.Name:lower()
					local isDelay=n:find("delay") or n:find("cooldown") or n:find("debounce") or n:find("firedelay")
					local isRate=n:find("firerate") or n:find("rpm")
					if isDelay or isRate then
						if not origFireRate[d] then origFireRate[d]=d.Value end
						if isDelay then d.Value=math.max(origFireRate[d]/CFG.FireRateMult,0.001)
						elseif isRate then d.Value=origFireRate[d]*CFG.FireRateMult end
					end
				end
			end
			task.wait(0.05)
		end
		for d,orig in pairs(origFireRate) do
			pcall(function() if d and d.Parent then d.Value=orig end end)
		end
		origFireRate={}
	end)
end
local function setupFullAuto(tool)
	arsenalHandles.fullAuto=true
	task.spawn(function()
		while arsenalHandles.fullAuto and CFG.FullAutoEnabled and tool and tool.Parent do
			if lmbHeld and tool.Parent==LocalPlayer.Character then pcall(function() tool:Activate() end) end
			task.wait(math.max(60/CFG.FullAutoRPM,0.02))
		end
	end)
end
local function stopArsenalMods()
	arsenalHandles.infAmmo=false; arsenalHandles.fireRate=false; arsenalHandles.fullAuto=false
end
local function applyArsenalWeaponMods(tool)
	if not tool then return end; stopArsenalMods(); task.wait(0.15)
	if CFG.InfAmmo         then setupInfAmmo(tool)  end
	if CFG.FireRateEnabled then setupFireRate(tool)  end
	if CFG.FullAutoEnabled then setupFullAuto(tool)  end
end
local function onToolEquipped(char)
	char.ChildAdded:Connect(function(child)
		if child:IsA("Tool") then applyArsenalWeaponMods(child) end
	end)
	for _,child in ipairs(char:GetChildren()) do
		if child:IsA("Tool") then applyArsenalWeaponMods(child) end
	end
end
if gameType=="Arsenal" then
	if LocalPlayer.Character then onToolEquipped(LocalPlayer.Character) end
	LocalPlayer.CharacterAdded:Connect(onToolEquipped)
end

