local function getKillTarget()
	local myHRP=getHRP(LocalPlayer); if not myHRP then return nil end
	local best,bd=nil,math.huge
	for _,plr in ipairs(Players:GetPlayers()) do
		if plr==LocalPlayer or not isAlive(plr) or not isEnemy(plr) or isKillWhitelisted(plr) then continue end
