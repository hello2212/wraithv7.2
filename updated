-- =============================================
-- RENDER LOOP — lightweight, critical only
-- =============================================
RunService:BindToRenderStep("WraithHub_Main", Enum.RenderPriority.Camera.Value+1, function()
	pcall(function()
		if CFG.FullBright then applyFullBright()
		elseif CFG.NoFog   then applyNoFog() end

		if gameType=="BB" then
			if BB_FOVCircle then
				BB_FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
				BB_FOVCircle.Radius = CFG.BB_FOVRadius
				BB_FOVCircle.Visible = CFG.BB_ShowFOV and CFG.AimbotEnabled
				if lockTarget then
					BB_FOVCircle.Color = Color3.fromRGB(0, 255, 0)
				else
					BB_FOVCircle.Color = Color3.fromRGB(255, 255, 255)
				end
			end

			if CFG.AimbotEnabled and isRmbDown then
				if not lockTarget or not lockTarget.Character or not lockTarget.Character.Parent then
					lockTarget = nil
					local closest = nil
					local shortestFOV = CFG.BB_FOVRadius 
					local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
					local camPos = Camera.CFrame.Position
					
					for _, charData in ipairs(GetBBCharacters()) do
						-- 3D DISTANCE LIMIT FIX
						local dist3D = (charData.Head.Position - camPos).Magnitude
						if dist3D > CFG.AimbotRange then continue end
						
						if not isBBEnemy(charData) then continue end
						
						local screen, onScreen = Camera:WorldToViewportPoint(charData.Head.Position)
						if not onScreen then continue end
						
						local dist2D = (Vector2.new(screen.X, screen.Y) - center).Magnitude
						if dist2D < shortestFOV then
							shortestFOV = dist2D
							closest = charData
						end
					end
					lockTarget = closest
				end
				
				if lockTarget and lockTarget.Head and lockTarget.Head.Parent then
					if CFG.BB_MouseAimbot and ExecutorCaps.hasMousemoverel then
						local screen, onScreen = Camera:WorldToViewportPoint(lockTarget.Head.Position)
						if onScreen then
							local mouseLoc = UserInputService:GetMouseLocation()
							local divisor = math.max(1, (1 - CFG.LockSmooth) * 30)
							mousemoverel((screen.X - mouseLoc.X)/divisor, (screen.Y - mouseLoc.Y)/divisor)
						end
					else
						Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, lockTarget.Head.Position), CFG.LockSmooth)
					end
				else
					lockTarget = nil
				end
			end
			
		elseif gameType=="AR2" and CFG.AimbotEnabled and isRmbDown then
			if AR2LockTarget then
				local ar2Plr=getPlayerFromCharacterModel(AR2LockTarget)
				if not isAR2ModelAlive(AR2LockTarget) or (ar2Plr and not isAimbotTarget(ar2Plr)) then
					AR2LockTarget=nil
				end
			end
			if not AR2LockTarget then AR2LockTarget=getClosestAR2Player() end
			if AR2LockTarget then
				local targetPart=(CFG.TargetPart=="Head" and getAR2ModelHead(AR2LockTarget))
					or getAR2ModelHRP(AR2LockTarget)
				if targetPart then
					local tPos=targetPart.Position
					if CFG.LeadShots and targetPart:IsA("BasePart") then
						tPos=tPos+targetPart.AssemblyLinearVelocity*CFG.PredictionAmt
					end
					aimbotMoveToTargetAR2(tPos)
				end
			end
			
		elseif gameType~="AR2" and gameType~="BB" and CFG.AimbotEnabled and isRmbDown then
			if lockTarget and not isAimbotTarget(lockTarget) then
				lockTarget=nil
			end
			if not lockTarget then lockTarget=getClosestPlayer() end
			if lockTarget then
				local tp=getTargetPart(lockTarget)
				if tp then
					local tPos=tp.Position
					if CFG.LeadShots then
						local hrp=getHRP(lockTarget)
						if hrp then tPos+=hrp.AssemblyLinearVelocity*CFG.PredictionAmt end
					end
					if gameType=="Rivals" and CFG.RIV_UseMousemoverel and ExecutorCaps.hasMousemoverel then
						local screenPos,onScreen=Camera:WorldToViewportPoint(tPos)
						if onScreen and screenPos.Z>0 then
							local mouseLoc=UserInputService:GetMouseLocation()
							local divisor=math.max(1,(1-CFG.LockSmooth)*30)
							mousemoverel((screenPos.X-mouseLoc.X)/divisor,(screenPos.Y-mouseLoc.Y)/divisor)
						end
					else
						aimbotMoveToTarget(tPos)
					end
				end
			end
		end

		if gameType=="AR2" then
			if AR2_SilentFovCircle then
				local ml=UserInputService:GetMouseLocation()
				AR2_SilentFovCircle.Position=ml
				AR2_SilentFovCircle.Radius=CFG.AR2SilentFov
				AR2_SilentFovCircle.Visible=CFG.SilentAim and CFG.AR2ShowSilentFov
			end
			if AR2_TargetDot then
				if CFG.SilentAim and AR2_SilentTarget and isAR2ModelAlive(AR2_SilentTarget) then
					local tp2=getAR2ModelHead(AR2_SilentTarget) or getAR2ModelHRP(AR2_SilentTarget)
					if tp2 then
						local sp,on=Camera:WorldToViewportPoint(tp2.Position)
						if on and sp.Z>0 then
							AR2_TargetDot.Position=Vector2.new(sp.X,sp.Y); AR2_TargetDot.Visible=true
						else AR2_TargetDot.Visible=false end
					end
				else AR2_TargetDot.Visible=false end
			end
		end

		if gameType~="AR2" and gameType~="BB" and CFG.JitterAim and isJitterDown then
			if jitterTarget and(not jitterTarget.Parent or not isAlive(jitterTarget) or isAimbotWhitelisted(jitterTarget)) then
				jitterTarget=nil
			end
			if not jitterTarget then jitterTarget=getClosestPlayer() end  -- already FOV-filtered
			if jitterTarget then
				local tp=getTargetPart(jitterTarget)
				if tp then
					jitterFlip=-jitterFlip
					local offset=Camera.CFrame.RightVector*(jitterFlip*CFG.JitterStrength*0.08)
					aimbotMoveToTarget(tp.Position+offset)
				end
			end
		end

		-- Shared FOV circle for all non-BB combat games
		if gameType~="BB" and AimbotFovCircle then
			if CFG.ShowFovCircle and CFG.AimbotEnabled then
				local vp=Camera.ViewportSize
				AimbotFovCircle.Position = Vector2.new(vp.X/2, vp.Y/2)
				AimbotFovCircle.Radius   = CFG.FovCircleRadius
				local hasLock = (lockTarget ~= nil and isAlive(lockTarget))
					or (AR2LockTarget ~= nil and isAR2ModelAlive(AR2LockTarget))
				AimbotFovCircle.Color   = hasLock
					and Color3.fromRGB(0,255,80)
					or  Color3.fromRGB(255,255,255)
				AimbotFovCircle.Visible = true
			else
				AimbotFovCircle.Visible = false
			end
		end

		if gameType~="AR2" and gameType~="BB" and CFG.SilentAim and isRmbDown and not CFG.AimbotEnabled and not CFG.JitterAim then
			local t=lockTarget or getClosestPlayer()
			if t then
				local tp=getTargetPart(t)
				if tp then Camera.CFrame=CFrame.new(Camera.CFrame.Position,tp.Position) end
			end
		end

		local hum=getHum(LocalPlayer)
		if hum then
			local targetWalkSpeed = CFG.SpeedBoost and CFG.WalkSpeed or 16
			local targetJumpPower = CFG.HighJump and CFG.JumpPower or 50
			if movementState.Humanoid ~= hum then
				movementState.Character = hum.Parent
				movementState.Humanoid = hum
				movementState.WalkSpeed = nil
				movementState.JumpPower = nil
			end
			if movementState.WalkSpeed ~= targetWalkSpeed then
				hum.WalkSpeed = targetWalkSpeed
				movementState.WalkSpeed = targetWalkSpeed
			end
			if movementState.JumpPower ~= targetJumpPower then
				hum.JumpPower = targetJumpPower
				movementState.JumpPower = targetJumpPower
			end
		end
		if CFG.NoClip then
			local char=getChar(LocalPlayer)
			if char then
				for _,v in ipairs(char:GetDescendants()) do
					if v:IsA("BasePart") then v.CanCollide=false end
				end
			end
		end
		if CFG.BunnyHop then
			local hrp=getHRP(LocalPlayer); local h=getHum(LocalPlayer)
			if hrp and h and hrp.AssemblyLinearVelocity.Y<0.1 then h:Jump() end
		end
		if CFG.ThirdPersonEnabled then
			local hrp=getHRP(LocalPlayer)
			if hrp then
				Camera.CFrame=CFrame.new(
					hrp.Position+Camera.CFrame.LookVector*-CFG.ThirdPersonDistance+Vector3.new(0,2,0),
					hrp.Position)
			end
		end
		if CFG.AntiAim then doAntiAim(getHRP(LocalPlayer)) end

		Stats.frameCount+=1
		if tick()-Stats.lastFPSUpdate>=1 then
			Stats.fps=Stats.frameCount; Stats.frameCount=0; Stats.lastFPSUpdate=tick()
		end
	end)
end)

