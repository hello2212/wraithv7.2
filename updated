		BronxTab:CreateToggle({Name="Kill All",CurrentValue=CFG.BRONX_KillAll,Flag="BRONX_KillAll",
			Callback=function(v)
				CFG.BRONX_KillAll=v
				if v then
					task.spawn(function()
						local RS=game:GetService("ReplicatedStorage")
						while CFG.BRONX_KillAll do
							task.wait(0.1)
							pcall(function()
								local Me=LocalPlayer
								local Gun=Me.Character and Me.Character:FindFirstChildOfClass("Tool")
								if Gun and Gun:FindFirstChild("Setting") then
									for _,Plr in pairs(Players:GetPlayers()) do
										if Plr~=Me and Plr.Character and Plr.Character:FindFirstChild("Humanoid") and Plr.Character.Humanoid.Health>0 then
											local Head=Plr.Character:FindFirstChild("Head")
											if Head then
												pcall(function()
													RS.VisualizeMuzzle:FireServer(Gun.Handle,true,{false,7,Color3.new(1,1,0),15,true,0.02},Gun.GunScript_Local.MuzzleEffect)
													RS.InflictTarget:FireServer(Gun,Me,Plr.Character.Humanoid,Head,9e9,{0,0,false,false,Gun.GunScript_Server.IgniteScript,Gun.GunScript_Server.IcifyScript,100,100},{false,5,3},Head,{false,{1930359546},1,1.5,1},Head.Position,Vector3.new(0,0,0),true)
												end)
											end
										end
									end
								end
							end)
						end
					end)
				end
				notify("Bronx Kill All",v and "ON" or "OFF",1.5); saveConfig()
			end})

		BronxTab:CreateSection("General Features")
		BronxTab:CreateLabel("Use the Combat, Movement, Character, and Visual tabs for universal features.")
	end

	if CFG.ShowCrosshair     then createCrosshair()  end
	if CFG.ShowFPS           then createFPS()         end
	if CFG.FlyEnabled        then startFly()         end
	if CFG.KillAllEnabled    then startKillAll()      end
	if CFG.FullBright        then applyFullBright()   end
	if CFG.NoFog             then applyNoFog()        end
	if CFG.XRayEnabled       then updateXRay()        end

	if gameType=="AR2" then
		task.spawn(initAR2SilentAim)
	end

	if gameType=="BSS" and CFG.BSS_AutoFarm then
		task.spawn(bssStartFarm)
	end

	if gameType=="RHT" and (CFG.RHT_NoRecoil or CFG.RHT_NoSpread or CFG.RHT_InfAmmo
		or CFG.RHT_FastShoot or CFG.RHT_NoSway or CFG.RHT_FullAuto) then
		task.spawn(rhtStartMods)
	end

	if gameType=="Arsenal" then
		local char=getChar(LocalPlayer)
		if char then
			local tool=char:FindFirstChildOfClass("Tool")
			if tool then task.spawn(function() applyArsenalWeaponMods(tool) end) end
		end
	end

	-- ── AUTO-START: Wrap Swapper + Device Spoofer ────────────────────────────
	-- Rivals only. If config had these active on last session, fire them now
	-- so the user doesn't have to manually toggle off/on after executing.
	if gameType=="Rivals" then
		task.spawn(function()
			task.wait(3) -- wait for game RemoteEvents / ViewModels to fully load
			-- Auto-apply saved wrap skin (anything except "original")
			if _RIV_applyToAllGuns_ref and CFG.RIV_WrapSkin and CFG.RIV_WrapSkin ~= "original" then
				pcall(function() _RIV_applyToAllGuns_ref(CFG.RIV_WrapSkin) end)
			end
			-- Auto-fire saved device spoof
			if _RIV_autoFireSpoof_ref then
				pcall(_RIV_autoFireSpoof_ref)
			end
		end)
	end

	-- ── MOBILE GUI TOGGLE BUTTON ─────────────────────────────────────────────
	-- Floating ghost button shown only on touch devices.
	-- Drag  : move the button anywhere on screen
	-- Tap   : open / close the hub (drag distance threshold = 12px)
	if UserInputService.TouchEnabled then
		task.spawn(function()
			local mobSg=Instance.new("ScreenGui")
			mobSg.Name="WraithHub_MobileToggle"; mobSg.ResetOnSpawn=false
			mobSg.IgnoreGuiInset=true; mobSg.DisplayOrder=300; mobSg.Parent=CoreGui

			-- outer frame so we can anchor the button by its centre
			local btn=Instance.new("TextButton",mobSg)
			btn.Text="ð»"
			btn.Size=UDim2.new(0,60,0,60)
			-- start bottom-right, above the thumb zone
			btn.Position=UDim2.new(1,-76,1,-120)
			btn.BackgroundColor3=Color3.fromRGB(72,28,200)
			btn.BorderSizePixel=0; btn.TextSize=28; btn.Font=Enum.Font.GothamBold
			btn.TextColor3=Color3.fromRGB(240,230,255); btn.ZIndex=300
			btn.AutoButtonColor=false
			Instance.new("UICorner",btn).CornerRadius=UDim.new(0,16)
			local stroke=Instance.new("UIStroke",btn)
			stroke.Color=Color3.fromRGB(170,90,255); stroke.Thickness=2.5

			-- subtle pulse glow so it's easy to spot
			task.spawn(function()
				local t=0
				while btn.Parent do
					t=t+0.04
					stroke.Thickness=2+math.abs(math.sin(t))*1.5
					task.wait(0.03)
				end
			end)

			-- drag logic: track finger from InputBegan → InputChanged → InputEnded
			-- if total travel < 12px it counts as a TAP, otherwise a DRAG
			local touchId=nil          -- tracks which finger owns the interaction
			local dragStart=nil        -- Vector3 screen position where touch began
			local btnStartPos=nil      -- UDim2 position of btn when touch began
			local hasDragged=false     -- true once finger moved > threshold
			local DRAG_THRESHOLD=12    -- pixels

			btn.InputBegan:Connect(function(input)
				if input.UserInputType~=Enum.UserInputType.Touch then return end
				if touchId~=nil then return end  -- ignore extra fingers
				touchId=input
				dragStart=input.Position
				btnStartPos=btn.Position
				hasDragged=false
				-- visual press feedback
				TweenService:Create(btn,TweenInfo.new(0.08),{Size=UDim2.new(0,54,0,54)}):Play()
			end)

			UserInputService.InputChanged:Connect(function(input)
				if input~=touchId then return end
				local delta=input.Position-dragStart
				if delta.Magnitude>DRAG_THRESHOLD then
					hasDragged=true
				end
				if hasDragged then
					btn.Position=UDim2.new(
						btnStartPos.X.Scale, btnStartPos.X.Offset+delta.X,
						btnStartPos.Y.Scale, btnStartPos.Y.Offset+delta.Y)
				end
			end)

			UserInputService.InputEnded:Connect(function(input)
				if input~=touchId then return end
				touchId=nil
				-- restore button size
				TweenService:Create(btn,TweenInfo.new(0.1),{Size=UDim2.new(0,60,0,60)}):Play()
				if not hasDragged then
					-- it was a clean tap — toggle the hub
					guiVisible=not guiVisible
					if mainGui then mainGui.Enabled=guiVisible end
					local onCol=Color3.fromRGB(72,28,200)
					local offCol=Color3.fromRGB(28,10,70)
					TweenService:Create(btn,TweenInfo.new(0.15),
						{BackgroundColor3=guiVisible and onCol or offCol}):Play()
					notify("Wraith Hub",guiVisible and "Opened â" or "Closed â",0.8)
				end
				hasDragged=false
			end)

			notify("Wraith Hub","Mobile mode â tap ghost button to open/close, drag to move it",3)
		end)
	end
end

