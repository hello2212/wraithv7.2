local function GetBBCharacters()
	local Result = {}
	if not BB_CharactersFolder then return Result end
	for _, Character in ipairs(BB_CharactersFolder:GetChildren()) do
		local Body = Character:FindFirstChild("Body")
		if not Body then continue end
		local Head = Body:FindFirstChild("Head")
		if not Head then continue end
		table.insert(Result, {Character = Character, Body = Body, Head = Head})
	end
	return Result
end

local BB_NametagCache = {}
local nextBBNametagUpdate = 0
local function isBBEnemy(charData)
	if not CFG.TeamCheck then return true end

	-- Refresh nametag Adornee cache every 1s
	local now = tick()
	if now > nextBBNametagUpdate then
		nextBBNametagUpdate = now + 1
		table.clear(BB_NametagCache)
		
		local function scanForNametags(folder)
			if not folder then return end
			for _, v in ipairs(folder:GetDescendants()) do
				if v:IsA("BillboardGui") and v.Adornee then
					local lbl = v:FindFirstChildWhichIsA("TextLabel", true)
					if lbl then
						BB_NametagCache[v.Adornee] = lbl.Text:upper()
					end
				end
			end
		end
		
		scanForNametags(game:GetService("CoreGui"))
		scanForNametags(LocalPlayer:FindFirstChild("PlayerGui"))
	end

	local targetTeamTxt = nil
	for part, text in pairs(BB_NametagCache) do
		if part == charData.Character or part:IsDescendantOf(charData.Character) then
			targetTeamTxt = text
			break
		end
	end

	if not targetTeamTxt then return true end -- Default to enemy if no tag found

	local myTeam = LocalPlayer.Team
	if not myTeam then return true end

	local myTeamName = myTeam.Name:upper()
	if targetTeamTxt:find(myTeamName) then
		return false -- Same team
	end

	return true
end

