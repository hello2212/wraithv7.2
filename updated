			RIV_cleanupConnections()
			for _, part in ipairs(obj:GetDescendants()) do
				if part:IsA("BasePart") then
					part.Material=Enum.Material.SmoothPlastic
					part.Transparency=0
					part.Color=Color3.fromRGB(200,200,200)
					part.CastShadow=true
				end
			end
		end

