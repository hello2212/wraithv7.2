local AR2_HookInstalled,AR2_BulletsOldFire=false,nil
local AR2_SilentFovCircle,AR2_TargetDot=nil,nil

local function createAR2FovCircle()
	pcall(function() if AR2_SilentFovCircle then AR2_SilentFovCircle:Remove() end end)
	pcall(function() if AR2_TargetDot       then AR2_TargetDot:Remove()       end end)
