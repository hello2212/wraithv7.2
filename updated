local function clearWorldESPObjects(cache, destroyAttachment)
	for inst, data in pairs(cache) do
		pcall(function()
			if data.BB then data.BB:Destroy() end
			if destroyAttachment and data.Att then data.Att:Destroy() end
		end)
		cache[inst] = nil
	end
end

local function disableWorldESPObjects(cache)
	for inst, data in pairs(cache) do
		if data.BB then data.BB.Enabled = false end
		if not inst or not inst.Parent then
			pcall(function()
				if data.BB then data.BB:Destroy() end
				if data.Att then data.Att:Destroy() end
			end)
			cache[inst] = nil
		end
	end
end

local function trimWorldESPObjects(cache, active, destroyAttachment)
	for inst, data in pairs(cache) do
		if not active[inst] or not inst or not inst.Parent then
			pcall(function()
				if data.BB then data.BB:Destroy() end
				if destroyAttachment and data.Att then data.Att:Destroy() end
			end)
			cache[inst] = nil
		end
	end
end

