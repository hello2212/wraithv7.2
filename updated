		local function RIV_sendPrimaryClick()
			local holdTime=0.03
			if mouse1click then
				local ok=pcall(mouse1click)
				if ok then return true end
			end
			if mouse1press and mouse1release then
				local ok=pcall(function()
					mouse1press()
					task.wait(holdTime)
					mouse1release()
				end)
				if ok then return true end
			end
			if mousedown and mouseup then
				local ok=pcall(function()
					mousedown()
					task.wait(holdTime)
					mouseup()
				end)
				if ok then return true end
			end
			if RIV_virtualInput then
				local mouseLoc=UserInputService:GetMouseLocation()
				local x,y=math.floor(mouseLoc.X),math.floor(mouseLoc.Y)
				local okDown=pcall(function() RIV_virtualInput:SendMouseButtonEvent(x,y,0,true,game,1) end)
				task.wait(holdTime)
				local okUp=pcall(function() RIV_virtualInput:SendMouseButtonEvent(x,y,0,false,game,1) end)
				if okDown or okUp then return true end
			end
			return false
		end

