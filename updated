local function aimbotMoveToTarget(targetPos)
	Camera.CFrame=Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position,targetPos),CFG.LockSmooth)
end

local function getClosestPlayer()
	local best,bestDist2D=nil,math.huge
	local myHRP=getHRP(LocalPlayer); if not myHRP then return nil end
	local center=Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
	local fovRadius=CFG.ShowFovCircle and CFG.FovCircleRadius or math.huge
	for _,plr in ipairs(Players:GetPlayers()) do
		if not isAimbotTarget(plr) then continue end
		local hrp=getHRP(plr); if not hrp then continue end
		local dist3D=(myHRP.Position-hrp.Position).Magnitude
		if dist3D>CFG.AimbotRange then continue end
		local tp=getTargetPart(plr); if not tp then continue end
		if not isVisible(tp) then continue end
		-- FOV circle filter: only lock targets whose screen position is inside the circle
		local sp,onScreen=Camera:WorldToViewportPoint(tp.Position)
		if not onScreen or sp.Z<=0 then continue end
		local dist2D=(Vector2.new(sp.X,sp.Y)-center).Magnitude
		if dist2D>fovRadius then continue end
		if dist2D<bestDist2D then bestDist2D=dist2D; best=plr end
	end
	return best
end

local function getPlayerFromCharacterModel(model)
	if not model then return nil end
	for _,plr in ipairs(Players:GetPlayers()) do
		if plr.Character==model then return plr end
	end
	return nil
end

-- ── AR2 Aimbot helpers ────────────────────────────────────────────────────
local function getAR2ModelHRP(model)
	return model:FindFirstChild("HumanoidRootPart")
		or model:FindFirstChild("UpperTorso") or model:FindFirstChild("Torso")
end
local function getAR2ModelHead(model) return model:FindFirstChild("Head") end
local function isAR2ModelAlive(model)
	if not model or not model.Parent then return false end
	local hum=model:FindFirstChildOfClass("Humanoid"); return hum and hum.Health>0
end

local function getClosestAR2Player()
	local folder=workspace:FindFirstChild("Characters")
	local myChar=getChar(LocalPlayer); local myHRP=getHRP(LocalPlayer); if not myHRP then return nil end
	local best,bestDist2D=nil,math.huge
	local center=Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
	local fovRadius=CFG.ShowFovCircle and CFG.FovCircleRadius or math.huge
	local function checkModel(model)
		if not model:IsA("Model") or model==myChar then return end
		local plr=getPlayerFromCharacterModel(model)
		if plr and isAimbotWhitelisted(plr) then return end
		if plr and not isEnemy(plr) then return end
		if not isAR2ModelAlive(model) then return end
		local hrp=getAR2ModelHRP(model); if not hrp then return end
		local dist=(myHRP.Position-hrp.Position).Magnitude
		if dist>CFG.AimbotRange then return end
		if CFG.VisibleCheck then
			local ray=Ray.new(Camera.CFrame.Position,(hrp.Position-Camera.CFrame.Position).Unit*600)
			local hit,pos=workspace:FindPartOnRayWithIgnoreList(ray,{myChar},false,true)
			if hit and (pos-hrp.Position).Magnitude>=5 then return end
		end
		-- FOV circle filter
		local targetPt=getAR2ModelHead(model) or hrp
		local sp,onScreen=Camera:WorldToViewportPoint(targetPt.Position)
		if not onScreen or sp.Z<=0 then return end
		local dist2D=(Vector2.new(sp.X,sp.Y)-center).Magnitude
		if dist2D>fovRadius then return end
		if dist2D<bestDist2D then bestDist2D=dist2D; best=model end
	end
	if folder then for _,m in ipairs(folder:GetChildren()) do checkModel(m) end end
	for _,plr in ipairs(Players:GetPlayers()) do
		if plr~=LocalPlayer then local c=getChar(plr); if c then checkModel(c) end end
	end
	return best
end

local function aimbotMoveToTargetAR2(targetPos)
	if ExecutorCaps.hasMousemoverel then
		local screenPos,onScreen=Camera:WorldToViewportPoint(targetPos)
		if onScreen and screenPos.Z>0 then
			local mouseLoc=UserInputService:GetMouseLocation()
			local divisor=math.max(1,(1-CFG.LockSmooth)*30)
			mousemoverel((screenPos.X-mouseLoc.X)/divisor,(screenPos.Y-mouseLoc.Y)/divisor)
		end
	else
		Camera.CFrame=Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position,targetPos),CFG.LockSmooth)
	end
end

