local function saveConfig()
	pcall(function()
		if not ExecutorCaps.hasWritefile then return end
		local sd={}
		for k,v in pairs(CFG) do
			local t=typeof(v)
			if t=="boolean" or t=="number" or t=="string" or t=="table" then sd[k]=v end
		end
		writefile(CONFIG_FILE, HttpService:JSONEncode(sd))
	end)
end

local function loadConfig()
	pcall(function()
		if not ExecutorCaps.hasReadfile or not ExecutorCaps.hasIsfile then return end
		if not isfile(CONFIG_FILE) then return end
		local data=HttpService:JSONDecode(readfile(CONFIG_FILE))
		for k,v in pairs(data) do if CFG_DEFAULTS[k]~=nil then CFG[k]=v end end
	end)
end

