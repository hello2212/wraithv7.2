	AR2_TargetDot.Filled=true; AR2_TargetDot.Color=Color3.fromRGB(180,80,255); AR2_TargetDot.Visible=false
end

local function ar2IsPointVisible(targetPos,targetCharacter)
	if not CFG.VisibleCheck then return true end
	local myChar=getChar(LocalPlayer)
	local rp=RaycastParams.new(); rp.FilterType=Enum.RaycastFilterType.Exclude
	rp.FilterDescendantsInstances={myChar,targetCharacter,Camera}; rp.IgnoreWater=true
	local result=workspace:Raycast(Camera.CFrame.Position,targetPos-Camera.CFrame.Position,rp)
	return result==nil
end

local function updateAR2SilentTarget()
	local folder=workspace:FindFirstChild("Characters")
	local myChar=getChar(LocalPlayer)
	local mouseLoc=UserInputService:GetMouseLocation()
	local best,bestDist=nil,CFG.AR2SilentFov
	local function checkModel(model)
		if not model:IsA("Model") or model==myChar then return end
		if not isAR2ModelAlive(model) then return end
		local head=getAR2ModelHead(model); local hrp=getAR2ModelHRP(model)
		if not head and not hrp then return end
		local cf=head and head.CFrame
		local pts=head and {
			head.Position,
			head.Position+cf.UpVector*0.3, head.Position-cf.UpVector*0.3,
			head.Position+cf.RightVector*0.3, head.Position-cf.RightVector*0.3,
		} or { hrp.Position }
		local validPoint=nil
		for _,pt in ipairs(pts) do
			if ar2IsPointVisible(pt,model) then validPoint=pt; break end
		end
		if not validPoint then return end
		local sp,onScreen=Camera:WorldToViewportPoint(validPoint)
		if not onScreen or sp.Z<=0 then return end
		local dist2D=(Vector2.new(sp.X,sp.Y)-mouseLoc).Magnitude
		if dist2D<bestDist then bestDist=dist2D; best=model end
	end
	if folder then for _,m in ipairs(folder:GetChildren()) do checkModel(m) end end
	for _,plr in ipairs(Players:GetPlayers()) do
		if plr~=LocalPlayer then local c=getChar(plr); if c then checkModel(c) end end
	end
	AR2_SilentTarget=best
end

local function initAR2SilentAim()
	if gameType~="AR2" then return end
	createAR2FovCircle()
	local function tryHook()
		local ok,err=pcall(function()
			local RF=game:GetService("ReplicatedFirst")
			local fw=RF:WaitForChild("Framework",15)
			if not fw then error("Framework not found") end
			local Framework=require(fw)
			if not Framework then error("require returned nil") end
			if type(Framework.WaitForLoaded)=="function" then pcall(function() Framework:WaitForLoaded() end) end
			local Libraries=Framework.Libraries; if not Libraries then error("Libraries nil") end
			local Bullets=Libraries.Bullets; if not Bullets then error("Bullets nil") end
			if type(Bullets.Fire)~="function" then error("Bullets.Fire not a function") end
			local OriginalFire=Bullets.Fire; AR2_BulletsOldFire=OriginalFire
			Bullets.Fire=function(self,...)
				local args={...}
				if CFG.SilentAim and AR2_SilentTarget and isAR2ModelAlive(AR2_SilentTarget) then
					local origin=args[4]
					if typeof(origin)~="Vector3" then
						local character=LocalPlayer.Character
						local tool=character and character:FindFirstChildOfClass("Tool")
						local handle=tool and (tool:FindFirstChild("Handle") or tool:FindFirstChild("Muzzle") or tool:FindFirstChildOfClass("BasePart"))
						origin=handle and handle.Position or Camera.CFrame.Position
					end
					if typeof(origin)=="Vector3" then
						local targetPart=getAR2ModelHead(AR2_SilentTarget) or getAR2ModelHRP(AR2_SilentTarget)
						if targetPart then
							local targetPos=targetPart.Position
							if CFG.LeadShots and targetPart:IsA("BasePart") then
								local ping=0.1; pcall(function() ping=LocalPlayer:GetNetworkPing() end)
								targetPos=targetPos+targetPart.AssemblyLinearVelocity*(ping+0.02)
							end
							local newDir=targetPos-origin
							if newDir.Magnitude>0 then args[5]=newDir.Unit end
						end
					end
				end
				return OriginalFire(self,table.unpack(args))
			end
			AR2_HookInstalled=true
		end)
		if ok then notify("AR2 Silent Aim","Hook installed ✓",3)
		else
			warn("[WRAITH HUB] AR2 silent aim hook failed: "..tostring(err))
			notifyUnsupported("AR2 Silent Aim")
		end
	end
	task.spawn(function()
		tryHook()
		if not AR2_HookInstalled then task.wait(6); if not AR2_HookInstalled then tryHook() end end
	end)
end

