			headerLbl.Position=UDim2.new(0,10,0,0); headerLbl.AutomaticSize=Enum.AutomaticSize.X
			headerLbl.TextXAlignment=Enum.TextXAlignment.Left

			local function getDisplayText()
				local keys={}; for k,v in pairs(selected) do if v then table.insert(keys,k) end end
				if #keys==0 then return "—" end
				return table.concat(keys,", ")
			end

			local valueLbl=Instance.new("TextLabel",header2)
			valueLbl.Text=getDisplayText(); valueLbl.TextColor3=P.textPri
			valueLbl.TextSize=12; valueLbl.Font=Enum.Font.GothamBold
			valueLbl.BackgroundTransparency=1; valueLbl.Size=UDim2.new(1,-50,1,0)
			valueLbl.Position=UDim2.new(0,10,0,0); valueLbl.TextXAlignment=Enum.TextXAlignment.Right
			valueLbl.TextTruncate=Enum.TextTruncate.AtEnd

			local arrow=Instance.new("TextLabel",header2); arrow.Text="▾"
			arrow.TextColor3=P.accent; arrow.TextSize=13; arrow.Font=Enum.Font.GothamBold
			arrow.BackgroundTransparency=1; arrow.Size=UDim2.new(0,22,1,0)
			arrow.Position=UDim2.new(1,-24,0,0)

			local optList=Instance.new("Frame",container); optList.BackgroundColor3=P.surface2
			optList.BorderSizePixel=0; optList.Position=UDim2.new(0,ITEM_PAD_L,0,CLOSED_H-2)
			optList.Size=UDim2.new(1,-ITEM_PAD_L*2,0,0)
			optList.AutomaticSize=Enum.AutomaticSize.Y; applyCorner(optList,8)
			applyStroke(optList,P.border,1)
			makeListLayout(optList,0); makePadding(optList,4,4,0,0)

			local open=false
			local function setOpen(v)
				open=v
				tween(arrow,{Rotation=v and 180 or 0},0.15):Play()
				if v then
					local totalH=CLOSED_H+#cfg2.Options*OPTION_H+8
					tween(container,{Size=UDim2.new(1,0,0,totalH)},0.18,Enum.EasingStyle.Back):Play()
				else
					tween(container,{Size=UDim2.new(1,0,0,CLOSED_H)},0.15):Play()
				end
			end

			local function makeOption(optName)
				local optBtn=Instance.new("TextButton",optList); optBtn.Text=""
				optBtn.Size=UDim2.new(1,0,0,OPTION_H); optBtn.BackgroundColor3=P.surface2
				optBtn.BackgroundTransparency=1; optBtn.BorderSizePixel=0

				local optBG=Instance.new("Frame",optBtn); optBG.Size=UDim2.new(1,-8,0,OPTION_H-4)
				optBG.Position=UDim2.new(0,4,0,2); optBG.BackgroundColor3=P.accentDim
				optBG.BackgroundTransparency=selected[optName] and 0 or 1; optBG.BorderSizePixel=0
				applyCorner(optBG,6)

				local checkLbl=Instance.new("TextLabel",optBtn)
				checkLbl.Text=selected[optName] and "✓" or ""
				checkLbl.TextColor3=P.accentBrt; checkLbl.TextSize=11; checkLbl.Font=Enum.Font.GothamBold
				checkLbl.BackgroundTransparency=1; checkLbl.Size=UDim2.new(0,22,1,0)
				checkLbl.Position=UDim2.new(0,8,0,0)

				local optLbl=Instance.new("TextLabel",optBtn); optLbl.Text=optName
				optLbl.TextColor3=selected[optName] and P.textPri or P.textSec
				optLbl.TextSize=12; optLbl.Font=Enum.Font.Gotham
				optLbl.BackgroundTransparency=1; optLbl.Size=UDim2.new(1,-30,1,0)
				optLbl.Position=UDim2.new(0,28,0,0); optLbl.TextXAlignment=Enum.TextXAlignment.Left

				optBtn.MouseEnter:Connect(function()
					if not selected[optName] then tween(optBG,{BackgroundTransparency=0.85},0.1):Play() end
					tween(optLbl,{TextColor3=P.textPri},0.1):Play()
				end)
				optBtn.MouseLeave:Connect(function()
					if not selected[optName] then tween(optBG,{BackgroundTransparency=1},0.1):Play() end
					tween(optLbl,{TextColor3=selected[optName] and P.textPri or P.textSec},0.1):Play()
				end)

				optBtn.MouseButton1Click:Connect(function()
					if multiMode then
						selected[optName]=not selected[optName]
					else
						for k in pairs(selected) do selected[k]=false end
						selected[optName]=true
					end
					checkLbl.Text=selected[optName] and "✓" or ""
					tween(optBG,{BackgroundTransparency=selected[optName] and 0 or 1},0.12):Play()
					tween(optLbl,{TextColor3=selected[optName] and P.textPri or P.textSec},0.12):Play()
					valueLbl.Text=getDisplayText()
					if not multiMode then setOpen(false) end
					if cfg2.Callback then
						if multiMode then cfg2.Callback(selected)
						else
							for k,v in pairs(selected) do
								if v then cfg2.Callback(k); break end
							end
						end
					end
				end)
			end

			for _,opt in ipairs(cfg2.Options) do makeOption(opt) end

			local zone=Instance.new("TextButton",header2); zone.Text=""
			zone.Size=UDim2.new(1,0,1,0); zone.BackgroundTransparency=1; zone.BorderSizePixel=0; zone.ZIndex=5
			zone.MouseButton1Click:Connect(function() setOpen(not open) end)
			header2.MouseEnter:Connect(function() tween(header2,{BackgroundColor3=P.surface},0.1):Play() end)
			header2.MouseLeave:Connect(function() tween(header2,{BackgroundColor3=P.surface3},0.1):Play() end)

			local dd={}
			function dd:Refresh(newOptions,keepSelected,replaceSelected)
				for _,c in ipairs(optList:GetChildren()) do
					if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
				end
				if replaceSelected~=nil then
					selected={}
					for _,v in ipairs(replaceSelected) do selected[v]=true end
				elseif not keepSelected then
					selected={}
				end
				cfg2.Options=newOptions
				for _,opt in ipairs(newOptions) do makeOption(opt) end
				valueLbl.Text=getDisplayText()
				if open then setOpen(false) end
			end

			if cfg2.Flag then tabs[cfg2.Flag]={type="dropdown",refresh=function(opts,ks) dd:Refresh(opts,ks) end} end
			return dd
		end

		return Tab
	end

	function Window:GetGuiFrame() return screenGui end
	return Window
end

