		-- ── Rage mousemoverel Aimbot ───────────────────────────────
		-- Ultra-aggressive: per-frame delta correction + prediction + FOV lock
		local function RAGE_stopAimbot()
			if RAGE_AimbotConn then RAGE_AimbotConn:Disconnect(); RAGE_AimbotConn=nil end
		end
		local function RAGE_startAimbot()
			RAGE_stopAimbot()
			RAGE_AimbotConn=RunService:BindToRenderStep("WraithRageAimbot",Enum.RenderPriority.Camera.Value+2,function()
				if not CFG.RAGE_MouseAimbot then RAGE_stopAimbot(); return end
				if not ExecutorCaps.hasMousemoverel then return end
				if not isRmbDown then return end
				local best,bestDist2D=nil,CFG.RAGE_AimbotFOV
				local center=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)
				local myHRP=getHRP(LocalPlayer)
				for _,plr in ipairs(Players:GetPlayers()) do
					if not isAimbotTarget(plr) then continue end
					local tp=getTargetPart(plr); if not tp then continue end
					local sp,on=Camera:WorldToViewportPoint(tp.Position)
					if not on or sp.Z<=0 then continue end
					local d2=(Vector2.new(sp.X,sp.Y)-center).Magnitude
					if d2<bestDist2D then bestDist2D=d2; best=plr end
				end
				if not best then return end
				local tp=getTargetPart(best); if not tp then return end
				local targetPos=tp.Position
				-- velocity prediction
				local hrp=getHRP(best)
				if hrp and hrp.AssemblyLinearVelocity.Magnitude>0.5 then
					local ping=0.08; pcall(function() ping=LocalPlayer:GetNetworkPing() end)
					targetPos=targetPos+hrp.AssemblyLinearVelocity*(ping+0.02)
				end
				local sp2,on2=Camera:WorldToViewportPoint(targetPos)
				if not on2 or sp2.Z<=0 then return end
				local ml=UserInputService:GetMouseLocation()
				local dx=sp2.X-ml.X; local dy=sp2.Y-ml.Y
				-- smooth factor: higher CFG.RAGE_AimbotSmooth = faster lock
				local factor=math.max(0.05,1-CFG.RAGE_AimbotSmooth)
				local moveX=dx*factor; local moveY=dy*factor
				-- clamp max per-frame pixels to avoid sudden jumps
				local maxPx=30
				moveX=math.clamp(moveX,-maxPx,maxPx)
				moveY=math.clamp(moveY,-maxPx,maxPx)
				if math.abs(moveX)>0.5 or math.abs(moveY)>0.5 then
					mousemoverel(moveX,moveY)
				end
			end)
		end

